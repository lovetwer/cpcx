{
  "version": 2,
  "buildCommand": "echo 'Build skipped - using pre-built files'",
  "outputDirectory": "dist/build/web",
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
